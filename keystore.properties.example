# Credenciales del keystore release de la APK.
# Copiar este archivo a `keystore.properties` (gitignored) y llenar con valores reales.
# El keystore real debe estar en `keystore/frutapp-release.jks` (gitignored).
#
# Generar uno nuevo:
#   keytool -genkeypair -v -keystore keystore/frutapp-release.jks \
#     -keyalg RSA -keysize 4096 -validity 10000 -alias frutapp
storeFile=keystore/frutapp-release.jks
storePassword=CAMBIAR_EN_PROD
keyAlias=frutapp
keyPassword=CAMBIAR_EN_PROD
