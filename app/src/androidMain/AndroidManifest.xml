<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Android 13+ exige permiso runtime para mostrar notificaciones. Pre-13 lo da
         por default. Lo pide MainActivity la primera vez que el user inicia sesion. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Ubicacion: el cliente la usa para autocompletar la direccion en checkout;
         el repartidor para reportar su posicion mientras esta EN_DESPACHO. FINE
         para precision de GPS; COARSE como fallback en interiores. Se piden
         runtime cuando hacen falta (no al instalar). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.FrutApp"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="false">
        <activity
            android:name="cl.frutapp.app.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|uiMode"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FrutApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FileProvider para compartir imágenes generadas (huella verde, canasta). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Servicio que recibe los mensajes de FCM. Android lo arranca aunque la
             app este cerrada (no force-stop). onMessageReceived / onNewToken. -->
        <service
            android:name="cl.frutapp.app.fcm.FrutAppMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Default channel id de FCM cuando no se especifica via data payload.
             Tiene que matchear el canal que crea la app en MainActivity. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="frutapp_orders" />

        <!-- API key de Google Maps. El placeholder ${MAPS_API_KEY} viene de
             local.properties (mapsApiKey=AIza...) o env var MAPS_API_KEY.
             Sin clave, el mapa carga gris pero la app no crashea. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />
    </application>

</manifest>
